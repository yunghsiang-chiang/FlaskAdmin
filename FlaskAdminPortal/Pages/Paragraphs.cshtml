@page
@model FlaskAdminPortal.Pages.ParagraphsModel
@{
    ViewData["Title"] = "段落列表";
}

<h2>段落管理（共 @Model.TotalItems 筆）</h2>

<div class="mb-3">
    <a class="btn btn-outline-secondary" asp-page="/SampledFiles">前往「已取樣檔案清單管理」</a>
</div>

<form method="get" class="row g-2 align-items-end mb-3">
    <div class="col-md-4">
        <label for="fileName" class="form-label">檔案名稱篩選</label>
        <select name="fileName" id="fileName" class="form-select">
            <option value="">全部檔案</option>
            @foreach (var sourceFile in Model.SourceFiles)
            {
                <option value="@sourceFile" selected="@(sourceFile == Model.fileName ? "selected" : null)">@sourceFile</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <label for="pageSize" class="form-label">每頁筆數</label>
        <select name="pageSize" id="pageSize" class="form-select">
            @if (Model.pageSize == 25)
            {
                <option value="25" selected>25</option>
            }
            else
            {
                <option value="25">25</option>
            }

            @if (Model.pageSize == 50)
            {
                <option value="50" selected>50</option>
            }
            else
            {
                <option value="50">50</option>
            }

            @if (Model.pageSize == 100)
            {
                <option value="100" selected>100</option>
            }
            else
            {
                <option value="100">100</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <label for="pageJump" class="form-label">頁碼</label>
        <select id="pageJump" name="currentPage" class="form-select">
            @for (int i = 1; i <= Math.Max(Model.TotalPages, 1); i++)
            {
                <option value="@i" selected="@(i == Model.currentPage ? "selected" : null)">第 @i 頁</option>
            }
        </select>
    </div>
    <div class="col-md-4">
        <button type="submit" class="btn btn-primary">套用篩選</button>
    </div>
</form>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}
else if (Model.Paragraphs.Count == 0)
{
    <div class="alert alert-info">尚無資料。</div>
}
else
{
    <div id="reload-status" class="my-2"></div>

    <form method="post" asp-page-handler="Reload" class="mb-3">
        <input type="hidden" name="fileName" value="@Model.fileName" />
        <input type="hidden" name="currentPage" value="@Model.currentPage" />
        <input type="hidden" name="pageSize" value="@Model.pageSize" />
        <button type="submit" class="btn btn-warning btn-sm">🔁 Reload Now</button>
        @if (!string.IsNullOrEmpty(Model.ReloadStatus))
        {
            <div class="mt-2">
                <span class="@(Model.ReloadStatus.StartsWith("✅") ? "text-success" : "text-danger")">
                    @Model.ReloadStatus
                </span>
            </div>
        }
    </form>

    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>內容</th>
                <th>操作</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model.Paragraphs)
            {
                <tr id="row-@p.Id">
                    <td>@p.Id</td>
                    <td>
                        <span class="text-display" id="text-display-@p.Id">@p.Text</span>
                        <input type="text" class="form-control text-edit d-none" id="text-edit-@p.Id" value="@p.Text" />
                    </td>
                    <td>
                        <button class="btn btn-sm btn-primary" onclick="editText('@p.Id', event)">Edit</button>
                        <button class="btn btn-sm btn-success d-none" onclick="submitText('@p.Id', event)">Submit</button>
                        <button class="btn btn-sm btn-danger" onclick="deleteParagraph('@p.Id', event)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <script>
        const adminApiBase = "/api/admin";
        const adminApiKey = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AdminApiKeyForClient));

        function buildHeaders(includeContentType = false) {
            const headers = {};
            if (includeContentType) {
                headers['Content-Type'] = 'application/json';
            }
            if (adminApiKey) {
                headers['X-Admin-API-Key'] = adminApiKey;
            }
            return headers;
        }

        function tryParseJson(text) {
            try {
                return JSON.parse(text);
            } catch {
                return null;
            }
        }

        function extractErrorMessage(payload, fallbackText) {
            if (!payload) return fallbackText;
            if (typeof payload === "string") return payload;
            if (payload.message) return payload.message;
            if (payload.error) return payload.error;
            if (payload.detail) return payload.detail;
            return fallbackText;
        }

        function editText(id, event) {
            event.preventDefault();
            document.getElementById(`text-display-${id}`).classList.add('d-none');
            document.getElementById(`text-edit-${id}`).classList.remove('d-none');
            event.target.classList.add('d-none');
            event.target.nextElementSibling.classList.remove('d-none');
        }

        async function submitText(id, event) {
            event.preventDefault();
            const newText = document.getElementById(`text-edit-${id}`).value;
            const res = await fetch(`${adminApiBase}/update/${id}`, {
                method: 'PUT',
                headers: buildHeaders(true),
                body: JSON.stringify({ text: newText })
            });

            const bodyText = await res.text();
            const payload = tryParseJson(bodyText);

            if (res.ok) {
                document.getElementById(`text-display-${id}`).innerText = newText;
                alert("✅ 修改成功！");
            } else {
                const msg = extractErrorMessage(payload, bodyText || "未知錯誤");
                alert(`❌ 修改失敗（HTTP ${res.status}）：${msg}`);
            }

            document.getElementById(`text-display-${id}`).classList.remove('d-none');
            document.getElementById(`text-edit-${id}`).classList.add('d-none');
            event.target.classList.add('d-none');
            event.target.previousElementSibling.classList.remove('d-none');

            await updateReloadStatus();
        }

        async function deleteParagraph(id, event) {
            event.preventDefault();
            if (!confirm(`確定要刪除段落 ID ${id} 嗎？`)) {
                return;
            }

            const res = await fetch(`${adminApiBase}/delete/${id}`, {
                method: 'DELETE',
                headers: buildHeaders(false)
            });

            const bodyText = await res.text();
            const payload = tryParseJson(bodyText);
            if (res.ok) {
                const row = document.getElementById(`row-${id}`);
                if (row) {
                    row.remove();
                }
                alert("✅ 刪除成功！");
            } else {
                const msg = extractErrorMessage(payload, bodyText || "未知錯誤");
                alert(`❌ 刪除失敗（HTTP ${res.status}）：${msg}`);
            }

            await updateReloadStatus();
        }

        async function updateReloadStatus() {
            try {
                const res = await fetch(`${adminApiBase}/reload-needed`, {
                    headers: buildHeaders(false)
                });
                const bodyText = await res.text();
                const json = tryParseJson(bodyText);
                const statusDiv = document.getElementById("reload-status");

                if (!res.ok) {
                    const msg = extractErrorMessage(json, bodyText || "未知錯誤");
                    statusDiv.innerHTML = `<span class="text-danger">❌ 無法取得伺服器狀態（HTTP ${res.status}）：${msg}</span>`;
                    return;
                }

                if (json?.reload_needed === true) {
                    statusDiv.innerHTML = '<span class="text-danger fw-bold">⚠️ 需要重新啟動伺服器服務</span>';
                } else {
                    statusDiv.innerHTML = '<span class="text-muted">✅ 不需重新啟動</span>';
                }
            } catch (err) {
                console.error("Failed to fetch reload-needed:", err);
                document.getElementById("reload-status").innerHTML =
                    '<span class="text-danger">❌ 無法取得伺服器狀態</span>';
            }
        }

        document.addEventListener("DOMContentLoaded", () => {
            updateReloadStatus();
        });
    </script>
}
